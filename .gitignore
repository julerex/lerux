# Generated by Cargo
# will have compiled files and executables
debug
target

# Kernel build output (justfile `build_dir` default: kernel, kernel.all, kernel.sym)
/build/

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

# QEMU bring-up build artifacts
qemu/*.o
qemu/*.elf
qemu/*.bin
qemu/*.img
qemu/build/
qemu/out/

# QEMU debug / smoke-test logs (written by qemu/debug.sh and qemu/smoke-test.sh)
qemu-int.log
qemu.log
qemu-serial.log

# Validation build outputs (committed: asm/, expected/)
kernel/validation/trampolines/out/

/.toolchain/

# Large upstream forks (fetch via scripts/fetch-vendor-sources.sh)
/vendor/sources/

# Vendored redoxfs host/target build artifacts
/vendor/redoxfs/target/

# Prefix sysroot tarballs merge under build/prefix/
/build/prefix/

# Rootfs disk images and staging
/build/rootfs.img
/build/rootfs-staging/
/build/rootfs-mnt/
/build/rust-install/
/build/prefix-sysroot
/vendor/relibc/target/

# Kernel local runtime config (auto-copied from config.toml.example by build.rs)
config.toml

# Userspace initfs staging build outputs
userspace/initfs-staging/bin/
userspace/initfs-staging/lib/drivers/virtio-blkd
userspace/initfs-staging/lib/ld64.so.1
userspace/initfs-staging/lib/libc.so
